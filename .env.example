# Copy this file to .env and fill the values. Do NOT commit real tokens.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=1508440217936334949
DISCORD_GUILD_ID=
DISCORD_REGISTER_COMMANDS=1
# Optional: restrict some behavior to a single channel
DISCORD_TEXT_CHANNEL_ID=

# TTS pool: run N Chatterbox processes in parallel for lower latency
# RME_CHATTERBOX_POOL_SIZE=2
# RME_CHATTERBOX_PORTS=8123,8124
# RME_CHATTERBOX_BASE_PORT=8123

# STT engine: auto (CUDA GPU → Parakeet, else → Whisper), parakeet, or whisper
# RME_STT_ENGINE=auto
# RME_PARAKEET_PORT=8127
# RME_PARAKEET_DEVICE=cuda
# RME_PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v2

# Enable streaming TTS for lower first-byte latency (experimental)
# RME_CHATTERBOX_STREAMING=true

# Path to Python interpreter that has chatterbox-streaming installed.
# chatterbox-streaming==0.1.2 requires Python 3.10/3.11 (torch==2.6.0 pin).
# RME_PYTHON_EXE=C:\Users\infor\AppData\Local\Programs\Python\Python311\python.exe

# Enable torch.compile on Chatterbox t3+s3gen for RTF reduction on Pascal GPUs.
# Warm-up inference at boot pays the one-time compile cost (~30-120s).
# RME_CHATTERBOX_COMPILE=true

# Silero VAD sidecar WebSocket port (separate from TTS)
# RME_VAD_PORT=8125

# TTS engine: auto (Magpie primary, Chatterbox fallback), magpie, or chatterbox
# RME_TTS_ENGINE=auto
# RME_MAGPIE_PORT=8129
# RME_MAGPIE_MODEL=nvidia/magpie_tts_multilingual_357m
# RME_MAGPIE_DEVICE=cuda
